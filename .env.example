# ============================================================
# 环境变量模板 —— 复制本文件为 .env 并填入实际值
#   cp .env.example .env
# 规则:前端能读到的变量必须以 VITE_ 开头
# ============================================================

# ----- 3D 模型地址 (3D Tiles tileset.json) -----
VITE_TILESET_SHIGANG=
VITE_TILESET_SHIPANTAN=

# ----- 天地图开发者 token (https://console.tianditu.gov.cn 自行申请) -----
VITE_TIANDITU_TOKEN=

# ----- 后端 API 地址 -----
VITE_API_BASE_URL=http://localhost:8080
